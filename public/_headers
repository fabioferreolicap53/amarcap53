# Assets com hash no nome → cache 1 ano
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS globais
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML → sem cache (sempre buscar nova versão)
/
  Cache-Control: no-cache

# Favicon e manifest
/favicon.ico
  Cache-Control: public, max-age=86400
/manifest.json
  Cache-Control: public, max-age=86400
